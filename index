<!-- ══ MAIN ══ -->
<main class="main-content">

  <!-- ─── ABA ENTRADA ─── -->
  <div id="tab-entrada" class="tab-panel">
    <div class="sec-title"><div class="sec-title-bar"></div><h2>Identificação e Parâmetros da Obra</h2></div>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:1.2rem;margin-bottom:1.2rem;">

      <div class="card">
        <div class="card-header"><div class="card-header-icon">📋</div><div class="card-header-title">1. Identificação da Obra</div></div>
        <div class="card-body">
          <div class="form-grid cols-2">
            <div class="form-group form-span-2">
              <label>Nome / Denominação da Obra</label>
              <input type="text" id="obra-nome" placeholder="Ex.: Pavimentação da Estrada do Tarumã-Açu" oninput="syncObra()"/>
            </div>
            <div class="form-group">
              <label>Tipo de Modal</label>
              <select id="obra-tipo" onchange="syncObra();renderParamCards()">
                <option>RAMAL / VICINAL</option>
                <option>RODOVIA ESTADUAL</option>
                <option>VIÁRIO URBANO</option>
                <option>MANUTENÇÃO RODOVIÁRIA</option>
              </select>
            </div>
            <div class="form-group">
              <label>Nº Orçamento (e-Obras)</label>
              <input type="text" id="obra-orcamento" placeholder="Ex.: 2025.001.0042"/>
            </div>
            <div class="form-group">
              <label>Localização (Município/UF)</label>
              <input type="text" id="obra-local" placeholder="Ex.: Manaus / AM"/>
            </div>
            <div class="form-group">
              <label>Rodovia / KM de Referência</label>
              <input type="text" id="obra-rodovia" placeholder="Ex.: AM-070 / km 12"/>
            </div>
            <div class="form-group">
              <label>Extensão Total (km)</label>
              <input type="number" id="obra-extensao" value="2" min="0.1" step="0.1" oninput="syncObra()"/>
            </div>
            <div class="form-group">
              <label>Número de Frentes</label>
              <input type="number" id="obra-frentes" value="2" min="1" step="1" oninput="syncObra()"/>
            </div>
          </div>
        </div>
      </div>

      <div style="display:flex;flex-direction:column;gap:1.2rem;">
        <div class="card">
          <div class="card-header"><div class="card-header-icon">📅</div><div class="card-header-title">2. Parâmetros de Planejamento</div></div>
          <div class="card-body">
            <div class="form-grid cols-2">
              <div class="form-group">
                <label>Data de Início Prevista</label>
                <input type="date" id="obra-inicio" oninput="syncObra()"/>
              </div>
              <div class="form-group">
                <label>Jornada de Trabalho (h/dia)</label>
                <input type="number" id="obra-jornada" value="8" min="4" max="12" step="0.5"/>
              </div>
              <div class="form-group">
                <label>Defasagem entre Frentes (dias)</label>
                <input type="number" id="obra-defasagem" value="7" min="1"/>
              </div>
              <div class="form-group">
                <label>Valor do Contrato (R$)</label>
                <input type="text" id="obra-valor" placeholder="0,00"/>
              </div>
            </div>
          </div>
        </div>

        <div class="card">
          <div class="card-header"><div class="card-header-icon">👷</div><div class="card-header-title">3. Responsável Técnico</div></div>
          <div class="card-body">
            <div class="form-grid cols-2">
              <div class="form-group form-span-2">
                <label>Nome do Responsável Técnico</label>
                <input type="text" id="obra-responsavel" placeholder="Nome completo"/>
              </div>
              <div class="form-group">
                <label>CREA-AM</label>
                <input type="text" id="obra-crea" placeholder="Ex.: 123456-D/AM"/>
              </div>
              <div class="form-group">
                <label>Cargo / Função</label>
                <input type="text" id="obra-cargo" value="Engenheiro de Planejamento"/>
              </div>
              <div class="form-group form-span-2">
                <label>E-mail</label>
                <input type="email" id="obra-email" placeholder="email@seinfra.am.gov.br"/>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Parâmetros do tipo de obra -->
    <div class="card">
      <div class="card-header"><div class="card-header-icon">⚙️</div><div class="card-header-title">Parâmetros de Prazo — Tipo Selecionado</div></div>
      <div class="card-body">
        <div class="param-cards" id="param-cards"></div>
      </div>
    </div>
  </div>

  <!-- ─── ABA SERVIÇOS ─── -->
  <div id="tab-servicos" class="tab-panel" style="display:none">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1rem;flex-wrap:wrap;gap:0.8rem;">
      <div class="sec-title" style="margin-bottom:0"><div class="sec-title-bar"></div><h2>Serviços e Quantitativos</h2></div>
      <div class="btn-group">
        <button class="btn btn-primary" onclick="addServico()">+ Adicionar Serviço</button>
        <button class="btn btn-outline btn-sm" onclick="calcularTudo()">🔄 Recalcular</button>
      </div>
    </div>

    <div class="table-wrap" style="margin-bottom:1rem;">
      <table id="tabela-servicos">
        <thead>
          <tr>
            <th>KM</th>
            <th>Etapa</th>
            <th style="min-width:300px">Composição (DNIT/SICRO2)</th>
            <th>Unid.</th>
            <th class="right">Qtde</th>
            <th class="right">QE</th>
            <th class="right" style="background:rgba(2,119,189,0.5)">MO Total (h)</th>
            <th class="right" style="background:rgba(2,119,189,0.5)">DP (dias)</th>
            <th class="right" style="background:rgba(245,166,35,0.5)">DA (dias)</th>
            <th></th>
          </tr>
        </thead>
        <tbody id="tbody-servicos"></tbody>
        <tfoot id="tfoot-servicos"></tfoot>
      </table>
    </div>

    <div class="kpi-row" id="kpis-servicos"></div>
    <div class="formulas">
      <div class="formula"><strong>DP</strong> = ROUNDUP(MO_Total / Jornada, 0)</div>
      <div class="formula"><strong>DA</strong> = ROUNDUP(DP / QE, 0) &nbsp;&nbsp;|&nbsp;&nbsp; QE = Quantidade de Equipes/Frentes</div>
      <div class="formula"><strong>QMO</strong> = ROUNDUP(Qtde × taxa_MO / (DA × Jornada), 0)</div>
      <div class="formula"><strong>QEQ</strong> = ROUNDUP(Qtde × taxa_EQP / (DA × Jornada), 0)</div>
    </div>
  </div>

  <!-- ─── ABA EAP ─── -->
  <div id="tab-eap" class="tab-panel" style="display:none">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1rem;flex-wrap:wrap;gap:0.8rem;">
      <div class="sec-title" style="margin-bottom:0"><div class="sec-title-bar"></div><h2>EAP — Estrutura Analítica do Projeto</h2></div>
      <div class="btn-group">
        <button class="btn btn-verde btn-sm" onclick="exportarPDF()">⬇ Exportar PDF</button>
        <button class="btn btn-outline btn-sm" onclick="exportarCSV()">⬇ Exportar CSV</button>
      </div>
    </div>

    <div class="kpi-row" id="kpis-eap"></div>
    <div class="table-wrap"><table id="tabela-eap">
      <thead>
        <tr>
          <th>#</th>
          <th>Etapa</th>
          <th style="min-width:240px">Serviço</th>
          <th>KM</th>
          <th>Unid.</th>
          <th class="right">Qtde</th>
          <th class="right">Produt.</th>
          <th class="right" style="background:rgba(2,119,189,0.4)">MO Total(h)</th>
          <th class="right" style="background:rgba(2,119,189,0.4)">DP(d)</th>
          <th class="right" style="background:rgba(100,100,100,0.3)">QE</th>
          <th class="right" style="background:rgba(245,166,35,0.4)">DA(d)</th>
          <th class="right" style="background:rgba(2,119,189,0.25)">Serv.</th>
          <th class="right" style="background:rgba(2,119,189,0.25)">Ped.</th>
          <th class="right" style="background:rgba(2,119,189,0.25)">Oper.</th>
          <th class="right" style="background:rgba(2,119,189,0.25)">Carp.</th>
          <th class="right" style="background:rgba(46,125,50,0.25)">Escav.</th>
          <th class="right" style="background:rgba(46,125,50,0.25)">Rolo</th>
          <th class="right" style="background:rgba(46,125,50,0.25)">Cam.</th>
          <th class="right" style="background:rgba(46,125,50,0.25)">Moto.</th>
        </tr>
        <tr style="background:#001d50">
          <th colspan="11"></th>
          <th colspan="4" style="text-align:center;font-size:0.62rem;background:rgba(2,119,189,0.35)">QMO</th>
          <th colspan="4" style="text-align:center;font-size:0.62rem;background:rgba(46,125,50,0.3)">QEQ</th>
        </tr>
      </thead>
      <tbody id="tbody-eap"></tbody>
      <tfoot id="tfoot-eap"></tfoot>
    </table></div>
    <div class="formulas" style="margin-top:1rem">
      <div class="formula"><strong>Fonte:</strong> DNIT-313 / SICRO2 / CPU / e-Obras — 38 composições</div>
      <div class="formula"><strong>DP</strong> = ROUNDUP(MO_Total / Jornada, 0)</div>
