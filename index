      ["Nº Orçamento",     getV("obra-orcamento")],
      ["Tipo de Modal",    getV("obra-tipo"),        true],
      ["Localização",      getV("obra-local")],
      ["Rodovia / KM Ref.",getV("obra-rodovia")],
      ["Extensão Total",   getV("obra-extensao")+" km", true],
    ]),
    card("📅","3. Planejamento Temporal",[
      ["Data de Início",          dataIni ? new Date(dataIni+"T00:00:00").toLocaleDateString("pt-BR") : "—"],
      ["Data de Término (prev.)", dataFim, true],
      ["Duração Total",           `${maxDia} dias corridos (${durMeses} meses)`, true],
      ["Jornada de Trabalho",     getV("obra-jornada")+"h/dia"],
