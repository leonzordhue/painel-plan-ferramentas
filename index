function addServico() {
  const tipo = getV("obra-tipo");
  const etapas = etapasDoTipo(tipo).filter(e => !PARAMETROS[tipo].find(p=>p.etapa===e&&!p.porKm));
  SERVICOS.push({ id:mkId(), km:"1", etapa:etapas[0]||"Terraplenagem", codigo:"2.2.2", qtde:0, qe:1 });
  calcularTudo();
}

function removeServico(id) {
  SERVICOS = SERVICOS.filter(s => s.id !== id);
  calcularTudo();
}

function updateServico(id, field, val) {
  const s = SERVICOS.find(s => s.id===id);
  if (!s) return;
  if (field==="qtde" || field==="qe") s[field] = parseFloat(val)||0;
  else s[field] = val;
  calcularTudo();
}

