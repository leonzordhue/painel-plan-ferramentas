<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>SEINFRA/AM — Plataforma de Planejamento de Obras</title>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet"/>
  <!-- Chart.js para histogramas -->
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
  <!-- jsPDF para exportação -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.7.0/jspdf.plugin.autotable.min.js"></script>

  <style>
    :root {
      --azul:         #002D72;
      --azul-hover:   #00348A;
      --azul-claro:   #EBF0FA;
      --azul-borda:   #C4D0E8;
      --amarelo:      #F5A623;
      --amarelo-cl:   #FEF3DC;
      --amarelo-brd:  #F5C878;
      --verde:        #007B3E;
      --verde-cl:     #E6F4ED;
      --verde-brd:    #A3D9B8;
      --vermelho:     #C0392B;
      --vermelho-cl:  #FDECEA;
      --cinza-txt:    #1A2540;
      --cinza-med:    #4A5568;
      --cinza-aux:    #8896A8;
      --cinza-bg:     #F5F7FB;
      --borda:        #E0E6F0;
      --branco:       #FFFFFF;
      --font:         'Outfit', sans-serif;
      --shadow:       0 2px 16px rgba(0,45,114,0.09), 0 0 0 1px var(--borda);
      --shadow-hover: 0 8px 32px rgba(0,45,114,0.14), 0 0 0 1px var(--azul-borda);
      --radius:       12px;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body { font-family: var(--font); background: var(--cinza-bg); color: var(--cinza-txt); -webkit-font-smoothing: antialiased; }
    a { text-decoration: none; color: inherit; }
    ::selection { background: rgba(0,45,114,0.14); }
    input, select, textarea { font-family: var(--font); }
    button { font-family: var(--font); cursor: pointer; }

    /* ══ TOPBAR ══ */
    .topbar {
      background: var(--azul); padding: 0.5rem 2rem;
      display: flex; align-items: center; justify-content: space-between;
    }
    .topbar-left { font-size: 0.68rem; letter-spacing: 0.08em; text-transform: uppercase; color: rgba(255,255,255,0.55); font-weight: 500; }
    .topbar-right { font-size: 0.68rem; font-weight: 600; color: var(--amarelo); letter-spacing: 0.05em; text-transform: uppercase; display: flex; align-items: center; gap: 0.5rem; }
    .topbar-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--amarelo); box-shadow: 0 0 8px var(--amarelo); animation: pulse 2s ease-in-out infinite; }

    /* ══ HEADER ══ */
    .site-header {
      background: var(--branco); border-bottom: 2px solid var(--azul);
      padding: 0.9rem 2rem; display: flex; align-items: center; justify-content: space-between;
      position: sticky; top: 0; z-index: 200; box-shadow: 0 2px 20px rgba(0,45,114,0.08);
    }
    .header-brand { display: flex; align-items: center; gap: 0.9rem; }
    .brand-escudo { width: 42px; height: 46px; border-radius: 8px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; overflow: hidden; }
    .brand-sup { font-size: 0.62rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--cinza-aux); margin-bottom: 0.1rem; }
    .brand-name { font-size: 1rem; font-weight: 800; color: var(--azul); letter-spacing: -0.01em; }
    .brand-name span { color: var(--amarelo); }
    .header-right { display: flex; align-items: center; gap: 1rem; }
    .header-badge { font-size: 0.68rem; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; color: var(--azul); background: var(--azul-claro); border: 1.5px solid var(--azul-borda); padding: 0.35em 0.9em; border-radius: 100px; }
    .header-obra-nome { font-size: 0.8rem; font-weight: 600; color: var(--cinza-med); max-width: 240px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

    /* ══ TABS ══ */
    .tabs-bar {
      background: var(--branco); border-bottom: 1px solid var(--borda);
      display: flex; align-items: center; gap: 0; overflow-x: auto; padding: 0 2rem;
      box-shadow: 0 1px 0 var(--borda);
    }
    .tab-btn {
      padding: 0.85rem 1.2rem; border: none; background: transparent;
      font-size: 0.75rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase;
      color: var(--cinza-aux); border-bottom: 3px solid transparent;
      transition: all 0.2s; white-space: nowrap; position: relative;
    }
    .tab-btn:hover { color: var(--azul); }
    .tab-btn.active { color: var(--azul); border-bottom-color: var(--amarelo); }
    .tab-badge { display: inline-block; margin-left: 6px; background: var(--amarelo-cl); color: var(--amarelo); border: 1px solid var(--amarelo-brd); border-radius: 100px; padding: 0 6px; font-size: 0.6rem; font-weight: 700; }
    .tab-badge.verde { background: var(--verde-cl); color: var(--verde); border-color: var(--verde-brd); }

    /* ══ CONTEÚDO ══ */
    .main-content { max-width: 1440px; margin: 0 auto; padding: 1.5rem 2rem 3rem; }

    /* ══ SECTION TITLE ══ */
    .sec-title { display: flex; align-items: center; gap: 0.8rem; margin-bottom: 1.2rem; }
    .sec-title-bar { width: 4px; height: 20px; background: var(--amarelo); border-radius: 2px; }
    .sec-title h2 { font-size: 1rem; font-weight: 700; color: var(--azul); letter-spacing: 0.04em; text-transform: uppercase; }
    .sec-title span { font-size: 0.7rem; color: var(--cinza-aux); font-weight: 500; }

    /* ══ CARDS ══ */
    .card { background: var(--branco); border-radius: var(--radius); box-shadow: var(--shadow); overflow: hidden; }
    .card-header { padding: 0.9rem 1.2rem; border-bottom: 1px solid var(--borda); display: flex; align-items: center; gap: 0.6rem; }
    .card-header-icon { width: 28px; height: 28px; border-radius: 6px; background: var(--azul-claro); display: flex; align-items: center; justify-content: center; font-size: 0.9rem; }
    .card-header-title { font-size: 0.78rem; font-weight: 700; color: var(--azul); text-transform: uppercase; letter-spacing: 0.06em; }
    .card-body { padding: 1.2rem; }

    /* ══ FORM GRID ══ */
    .form-grid { display: grid; gap: 1rem; }
    .form-grid.cols-2 { grid-template-columns: 1fr 1fr; }
    .form-grid.cols-3 { grid-template-columns: 1fr 1fr 1fr; }
    .form-grid.cols-4 { grid-template-columns: repeat(4, 1fr); }
    .form-group { display: flex; flex-direction: column; gap: 0.35rem; }
    .form-group label { font-size: 0.68rem; font-weight: 700; color: var(--cinza-aux); text-transform: uppercase; letter-spacing: 0.08em; }
    .form-group input, .form-group select, .form-group textarea {
      padding: 0.6rem 0.8rem; border: 1.5px solid var(--borda); border-radius: 8px;
      font-size: 0.85rem; color: var(--cinza-txt); background: var(--branco);
      transition: border-color 0.2s; width: 100%;
    }
    .form-group input:focus, .form-group select:focus, .form-group textarea:focus {
      outline: none; border-color: var(--azul); box-shadow: 0 0 0 3px rgba(0,45,114,0.08);
    }
    .form-span-2 { grid-column: span 2; }
    .form-span-3 { grid-column: span 3; }
    .form-span-full { grid-column: 1 / -1; }

    /* ══ PARAM CARDS ══ */
    .param-cards { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 0.8rem; }
    .param-card { background: var(--cinza-bg); border-radius: 10px; padding: 0.9rem 1rem; border-left: 4px solid var(--azul); }
    .param-card-type { font-size: 0.6rem; color: var(--cinza-aux); font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 0.3rem; }
    .param-card-etapa { font-size: 0.82rem; font-weight: 600; color: var(--cinza-txt); margin-bottom: 0.4rem; }
    .param-card-dias { font-size: 1.4rem; font-weight: 800; color: var(--azul); }
    .param-card-dias span { font-size: 0.65rem; font-weight: 500; color: var(--cinza-aux); }

    /* ══ BUTTONS ══ */
    .btn { display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.6rem 1.2rem; border: none; border-radius: 8px; font-size: 0.78rem; font-weight: 700; letter-spacing: 0.04em; transition: all 0.2s; }
    .btn-primary { background: var(--azul); color: var(--branco); }
    .btn-primary:hover { background: var(--azul-hover); box-shadow: 0 4px 16px rgba(0,45,114,0.25); }
    .btn-amarelo { background: var(--amarelo); color: var(--branco); }
    .btn-amarelo:hover { background: #e09520; box-shadow: 0 4px 16px rgba(245,166,35,0.3); }
    .btn-verde { background: var(--verde); color: var(--branco); }
    .btn-verde:hover { background: #006830; }
    .btn-outline { background: transparent; color: var(--azul); border: 1.5px solid var(--azul-borda); }
    .btn-outline:hover { background: var(--azul-claro); }
    .btn-danger { background: transparent; color: var(--vermelho); border: 1.5px solid rgba(192,57,43,0.3); padding: 0.35rem 0.7rem; font-size: 0.72rem; }
    .btn-danger:hover { background: var(--vermelho-cl); }
    .btn-sm { padding: 0.4rem 0.8rem; font-size: 0.72rem; }
    .btn-group { display: flex; gap: 0.6rem; align-items: center; flex-wrap: wrap; }

    /* ══ TABELA ══ */
    .table-wrap { overflow-x: auto; border-radius: var(--radius); box-shadow: var(--shadow); }
    table { width: 100%; border-collapse: collapse; background: var(--branco); font-size: 0.82rem; }
    thead tr { background: var(--azul); }
    thead th { padding: 0.75rem 0.8rem; text-align: left; font-size: 0.65rem; font-weight: 700; color: rgba(255,255,255,0.85); text-transform: uppercase; letter-spacing: 0.08em; white-space: nowrap; }
    thead th.right { text-align: right; }
    tbody tr:nth-child(even) { background: var(--cinza-bg); }
    tbody tr:hover { background: var(--azul-claro); }
    tbody td { padding: 0.65rem 0.8rem; color: var(--cinza-txt); border-bottom: 1px solid var(--borda); font-size: 0.82rem; white-space: nowrap; }
    tbody td.right { text-align: right; font-variant-numeric: tabular-nums; }
    tbody td.mono { font-variant-numeric: tabular-nums; }
    tbody td.bold { font-weight: 700; }
    .td-etapa { display: flex; align-items: center; gap: 8px; }
    .etapa-dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }
    tfoot tr { background: var(--azul); }
    tfoot td { padding: 0.7rem 0.8rem; font-weight: 700; color: var(--branco); font-size: 0.82rem; border: none; }
    tfoot td.right { text-align: right; }

    /* ══ INPUT INLINE ══ */
    .input-inline { padding: 0.35rem 0.5rem; border: 1.5px solid var(--borda); border-radius: 6px; font-size: 0.8rem; color: var(--cinza-txt); background: var(--branco); width: 100%; transition: border-color 0.2s; }
    .input-inline:focus { outline: none; border-color: var(--azul); }
    .input-inline.w40 { width: 48px; text-align: center; }
    .input-inline.w60 { width: 70px; }
    .input-inline.w80 { width: 90px; }

    /* ══ KPIS ══ */
    .kpi-row { display: grid; grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); gap: 0.8rem; margin-bottom: 1.2rem; }
    .kpi { background: var(--branco); border-radius: var(--radius); padding: 1rem 1.1rem; box-shadow: var(--shadow); border-top: 3px solid var(--azul); }
    .kpi-label { font-size: 0.62rem; font-weight: 700; color: var(--cinza-aux); text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 0.4rem; }
    .kpi-value { font-size: 1.6rem; font-weight: 800; color: var(--azul); line-height: 1; }
    .kpi-value.amarelo { color: var(--amarelo); }
    .kpi-value.verde { color: var(--verde); }
    .kpi-unit { font-size: 0.65rem; color: var(--cinza-aux); font-weight: 500; margin-top: 0.2rem; }

    /* ══ GANTT ══ */
    #gantt-scroll { overflow-x: auto; background: var(--branco); border-radius: var(--radius); box-shadow: var(--shadow); }
    #gantt-svg { display: block; }

    /* ══ HISTOGRAMA ══ */
    .chart-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.2rem; }
    .chart-card { background: var(--branco); border-radius: var(--radius); box-shadow: var(--shadow); padding: 1.2rem; }
    .chart-title { font-size: 0.75rem; font-weight: 700; color: var(--azul); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 1rem; }

    /* ══ MEMORIAL ══ */
    .memorial-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
    .memorial-row { display: flex; justify-content: space-between; padding: 0.6rem 0; border-bottom: 1px solid var(--borda); align-items: center; }
    .memorial-label { font-size: 0.75rem; color: var(--cinza-aux); font-weight: 500; }
    .memorial-value { font-size: 0.82rem; color: var(--cinza-txt); font-weight: 600; text-align: right; max-width: 60%; }
    .memorial-value.accent { color: var(--azul); font-weight: 700; }

    /* ══ GANTT LEGEND ══ */
    .gantt-legend { display: flex; gap: 1rem; flex-wrap: wrap; margin-top: 0.8rem; }
    .legend-item { display: flex; align-items: center; gap: 0.4rem; font-size: 0.7rem; color: var(--cinza-aux); }
    .legend-dot { width: 10px; height: 10px; border-radius: 3px; }

    /* ══ ALERT ══ */
    .alert { padding: 1rem 1.2rem; border-radius: 8px; font-size: 0.82rem; display: flex; align-items: center; gap: 0.7rem; margin-bottom: 1rem; }
    .alert-info { background: var(--azul-claro); color: var(--azul); border: 1px solid var(--azul-borda); }
    .alert-warn { background: var(--amarelo-cl); color: #8a5a00; border: 1px solid var(--amarelo-brd); }
    .alert-success { background: var(--verde-cl); color: var(--verde); border: 1px solid var(--verde-brd); }

    /* ══ FORMULAS ══ */
    .formulas { display: flex; flex-wrap: wrap; gap: 1rem; background: var(--cinza-bg); border-radius: 8px; padding: 0.8rem 1rem; margin-top: 1rem; }
    .formula { font-size: 0.72rem; color: var(--cinza-med); font-family: 'Courier New', monospace; }
    .formula strong { color: var(--azul); }

    /* ══ FOOTER ══ */
    .site-footer { background: var(--azul); color: rgba(255,255,255,0.6); padding: 1.5rem 2rem; margin-top: 3rem; }
    .footer-inner { max-width: 1440px; margin: 0 auto; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 1rem; }
    .footer-brand { display: flex; align-items: center; gap: 0.8rem; }
    .footer-name { font-size: 1rem; font-weight: 800; color: var(--branco); }
    .footer-name span { color: var(--amarelo); }
    .footer-sub { font-size: 0.68rem; color: rgba(255,255,255,0.5); }
    .footer-copy { font-size: 0.68rem; }

    /* ══ ANIMAÇÕES ══ */
    @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.4; } }
    @keyframes fadeIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: none; } }
    .tab-panel { animation: fadeIn 0.25s ease; }

    /* ══ EMPTY STATE ══ */
    .empty-state { text-align: center; padding: 3rem; color: var(--cinza-aux); }
    .empty-state-icon { font-size: 2.5rem; margin-bottom: 0.8rem; }
    .empty-state p { font-size: 0.9rem; }

    /* ══ RESPONSIVE ══ */
    @media (max-width: 900px) {
      .form-grid.cols-2, .form-grid.cols-3, .form-grid.cols-4 { grid-template-columns: 1fr; }
      .chart-grid { grid-template-columns: 1fr; }
      .memorial-grid { grid-template-columns: 1fr; }
      .main-content { padding: 1rem; }
    }

    /* ══ PRINT ══ */
    @media print {
      .topbar, .site-header, .tabs-bar, .btn-group, .btn, .site-footer { display: none !important; }
      body { background: white; }
      .card { box-shadow: none; border: 1px solid #ccc; }
    }

    /* select input full width fix */
    select { appearance: auto; }

    .color-mo  { color: #0277BD; }
    .color-eqp { color: #2E7D32; }
    .color-da  { color: var(--amarelo); }
    .bg-mo { background: #E3F2FD; }
    .bg-eqp { background: #E8F5E9; }
    td.da { color: var(--amarelo); font-weight: 700; }
    td.dp { color: #0277BD; }
    td.mo { color: #2E7D32; }

    /* ══ BOTÃO IMPRIMIR NA TABS BAR ══ */
    .btn-imprimir {
      font-family: var(--font); font-size: 0.75rem; font-weight: 700;
      background: var(--azul); color: var(--branco);
      border: none; border-radius: 8px; padding: 0.5em 1.1em;
      cursor: pointer; display: flex; align-items: center; gap: 0.4rem;
      transition: all 0.18s; letter-spacing: 0.03em; white-space: nowrap;
    }
    .btn-imprimir:hover { background: var(--amarelo); color: var(--azul); transform: translateY(-1px); box-shadow: 0 4px 14px rgba(245,166,35,0.35); }

    /* ══ MODAL DE IMPRESSÃO ══ */
    .print-overlay {
      position: fixed; inset: 0; z-index: 1000;
      background: rgba(0,20,60,0.55); backdrop-filter: blur(4px);
      display: flex; align-items: flex-start; justify-content: center;
      padding: 1.5rem 1rem 1rem; overflow-y: auto;
      opacity: 0; pointer-events: none; transition: opacity 0.22s;
    }
    .print-overlay.open { opacity: 1; pointer-events: all; }
    .print-modal {
      background: var(--branco); border-radius: 16px; width: 100%; max-width: 1200px;
      box-shadow: 0 24px 80px rgba(0,20,60,0.35), 0 0 0 1px rgba(0,45,114,0.12);
      overflow: hidden; transform: translateY(16px); transition: transform 0.25s;
      display: flex; flex-direction: column;
    }
    .print-overlay.open .print-modal { transform: translateY(0); }

    /* Toolbar do modal */
    .print-toolbar {
      background: var(--azul); padding: 1rem 1.5rem;
      display: flex; align-items: center; justify-content: space-between; gap: 1rem; flex-wrap: wrap;
    }
    .print-toolbar-left { display: flex; align-items: center; gap: 0.85rem; }
    .print-toolbar-icon { font-size: 1.4rem; }
    .print-toolbar-title { font-size: 1rem; font-weight: 800; color: var(--branco); }
    .print-toolbar-sub { font-size: 0.72rem; color: rgba(255,255,255,0.6); margin-top: 0.1rem; }
    .print-toolbar-actions { display: flex; gap: 0.5rem; align-items: center; }
    .btn-pdf-action {
      font-family: var(--font); font-size: 0.8rem; font-weight: 700;
      background: var(--amarelo); color: var(--azul); border: none;
      border-radius: 8px; padding: 0.55em 1.2em; cursor: pointer;
      display: flex; align-items: center; gap: 0.4rem; transition: all 0.15s;
    }
    .btn-pdf-action:hover { background: #f0c060; transform: translateY(-1px); }
    .btn-fechar-modal {
      width: 32px; height: 32px; border-radius: 8px;
      background: rgba(255,255,255,0.12); border: none;
      color: rgba(255,255,255,0.8); font-size: 1rem; cursor: pointer;
      display: flex; align-items: center; justify-content: center; transition: background 0.15s;
    }
    .btn-fechar-modal:hover { background: rgba(255,255,255,0.22); }

    /* Seletor de seções */
    .print-section-selector {
      background: var(--cinza-bg); border-bottom: 1px solid var(--borda);
      padding: 1rem 1.5rem; display: flex; align-items: center; gap: 1.5rem; flex-wrap: wrap;
    }
    .print-selector-title { font-size: 0.72rem; font-weight: 700; color: var(--cinza-aux); text-transform: uppercase; letter-spacing: 0.08em; white-space: nowrap; }
    .print-checkboxes { display: flex; gap: 0.6rem; flex-wrap: wrap; flex: 1; }
    .print-check-item {
      display: flex; align-items: center; gap: 0.5rem; cursor: pointer;
      font-size: 0.78rem; font-weight: 500; color: var(--cinza-txt);
      background: var(--branco); border: 1.5px solid var(--borda);
      border-radius: 8px; padding: 0.4em 0.85em; transition: all 0.15s; user-select: none;
    }
    .print-check-item:has(input:checked) { border-color: var(--azul); background: var(--azul-claro); color: var(--azul); }
    .print-check-item input { display: none; }
    .pcheck-box {
      width: 14px; height: 14px; border: 2px solid var(--borda); border-radius: 3px;
      display: inline-flex; align-items: center; justify-content: center; flex-shrink: 0; transition: all 0.15s;
    }
    .print-check-item:has(input:checked) .pcheck-box { background: var(--azul); border-color: var(--azul); }
    .print-check-item:has(input:checked) .pcheck-box::after { content: '✓'; font-size: 9px; color: white; font-weight: 800; }
    .print-tip { font-size: 0.7rem; color: var(--cinza-aux); width: 100%; margin-top: 0.3rem; }

    /* Área de preview */
    .print-preview-area {
      padding: 1.5rem; overflow-y: auto; max-height: calc(100vh - 220px);
      background: #e8ecf4;
    }

    /* Páginas do preview */
    .print-page {
      background: white; border-radius: 6px; margin-bottom: 1.5rem;
      box-shadow: 0 4px 20px rgba(0,0,0,0.12); overflow: hidden;
      page-break-after: always;
    }
    .print-page:last-child { margin-bottom: 0; }
    .print-page-capa {
      background: var(--azul); padding: 2rem 2.5rem; position: relative; overflow: hidden;
    }
    .print-page-capa::before {
      content:''; position:absolute; left:0; top:0; bottom:0; width:6px;
      background: linear-gradient(to bottom, var(--amarelo), rgba(245,166,35,0.1));
    }
    .print-page-capa::after {
      content:''; position:absolute; inset:0;
      background: repeating-linear-gradient(-50deg, transparent, transparent 50px, rgba(255,255,255,0.015) 50px, rgba(255,255,255,0.015) 51px);
    }
    .print-capa-inner { position:relative; z-index:1; }
    .print-capa-gov { font-size:0.65rem; font-weight:600; letter-spacing:0.12em; text-transform:uppercase; color:rgba(255,255,255,0.5); margin-bottom:0.4rem; }
    .print-capa-title { font-size:1.6rem; font-weight:900; color:#fff; letter-spacing:-0.02em; margin-bottom:0.3rem; }
    .print-capa-nome { font-size:1rem; font-weight:700; color:var(--amarelo); margin-bottom:1rem; }
    .print-capa-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:0; border-top:1px solid rgba(255,255,255,0.12); }
    .print-capa-item { padding:0.9rem 1rem; border-right:1px solid rgba(255,255,255,0.1); }
    .print-capa-item:last-child { border-right:none; }
    .print-capa-lbl { font-size:0.58rem; font-weight:700; letter-spacing:0.12em; text-transform:uppercase; color:rgba(255,255,255,0.45); margin-bottom:0.3rem; }
    .print-capa-val { font-size:0.9rem; font-weight:700; color:#fff; }

    .print-section-title {
      background: var(--azul-claro); border-left: 5px solid var(--azul);
      padding: 0.6rem 1.2rem; display: flex; align-items: center; gap: 0.6rem;
      font-size: 0.75rem; font-weight: 800; color: var(--azul); text-transform: uppercase; letter-spacing: 0.08em;
    }
    .print-section-body { padding: 1.2rem; }

    /* Tabelas no preview */
    .ptable { width:100%; border-collapse:collapse; font-size:0.72rem; font-family:var(--font); }
    .ptable thead tr { background: var(--azul); }
    .ptable thead th { padding:0.5rem 0.6rem; color:rgba(255,255,255,0.9); font-size:0.6rem; font-weight:700; text-transform:uppercase; letter-spacing:0.06em; text-align:left; white-space:nowrap; }
    .ptable thead th.r { text-align:right; }
    .ptable tbody tr:nth-child(even) { background: var(--cinza-bg); }
    .ptable tbody td { padding:0.45rem 0.6rem; border-bottom:1px solid #eee; color:var(--cinza-txt); white-space:nowrap; }
    .ptable tbody td.r { text-align:right; font-variant-numeric:tabular-nums; }
    .ptable tfoot tr { background: var(--azul); }
    .ptable tfoot td { padding:0.5rem 0.6rem; color:white; font-weight:700; font-size:0.7rem; }
    .ptable tfoot td.r { text-align:right; }

    /* KPIs no preview */
    .print-kpis { display:grid; grid-template-columns:repeat(5,1fr); gap:0.7rem; margin-bottom:0.8rem; }
    .print-kpi { background:var(--cinza-bg); border-radius:8px; padding:0.7rem 0.9rem; border-top:3px solid var(--azul); }
    .print-kpi-lbl { font-size:0.58rem; font-weight:700; color:var(--cinza-aux); text-transform:uppercase; letter-spacing:0.08em; margin-bottom:0.2rem; }
    .print-kpi-val { font-size:1.3rem; font-weight:800; color:var(--azul); line-height:1; }
    .print-kpi-unit { font-size:0.58rem; color:var(--cinza-aux); }

    /* Memorial no preview */
    .print-memorial-grid { display:grid; grid-template-columns:1fr 1fr; gap:1rem; }
    .print-memorial-card { background:var(--cinza-bg); border-radius:8px; overflow:hidden; }
    .print-memorial-card-hdr { background:var(--azul); padding:0.5rem 0.9rem; font-size:0.68rem; font-weight:700; color:rgba(255,255,255,0.9); text-transform:uppercase; letter-spacing:0.06em; }
    .print-memorial-row { display:flex; justify-content:space-between; padding:0.45rem 0.9rem; border-bottom:1px solid var(--borda); }
    .print-memorial-lbl { font-size:0.7rem; color:var(--cinza-aux); }
    .print-memorial-val { font-size:0.75rem; font-weight:700; color:var(--azul); text-align:right; }

    /* Gantt no preview - usa o SVG gerado */
    .print-gantt-wrap { overflow-x:auto; }

    /* ══ @MEDIA PRINT ══ */
    @media print {
      * { -webkit-print-color-adjust: exact !important; print-color-adjust: exact !important; }
      body { background: white !important; margin: 0; padding: 0; }

      /* Esconde tudo exceto o modal aberto */
      .topbar, .site-header, .tabs-bar, .main-content, .site-footer { display: none !important; }

      /* Abre o overlay para impressão */
      .print-overlay {
        position: static !important; display: block !important; padding: 0 !important;
        background: none !important; backdrop-filter: none !important; overflow: visible !important;
        opacity: 1 !important; pointer-events: none !important;
      }
      .print-modal {
        max-width: 100% !important; border-radius: 0 !important; box-shadow: none !important;
        transform: none !important;
      }
      .print-toolbar, .print-section-selector, .btn-pdf-action, .btn-fechar-modal { display: none !important; }
      .print-preview-area {
        max-height: none !important; overflow: visible !important; background: white !important;
        padding: 0 !important;
      }

      /* Páginas */
      .print-page { border-radius: 0 !important; box-shadow: none !important; margin: 0 !important; page-break-after: always; }

      /* Capa azul forçada */
      .print-page-capa { background: #002D72 !important; }
      .print-capa-grid { background: #002D72 !important; border-color: rgba(255,255,255,0.12) !important; }
      .print-capa-item { background: #002D72 !important; }
      .print-capa-val { color: #ffffff !important; }
      .print-capa-lbl { color: rgba(255,255,255,0.5) !important; }
      .print-capa-nome { color: #F5A623 !important; }

      /* Titles */
      .print-section-title { background: #EBF0FA !important; border-color: #002D72 !important; color: #002D72 !important; }

      /* Tabelas */
      .ptable thead tr { background: #002D72 !important; }
      .ptable thead th { color: rgba(255,255,255,0.9) !important; }
      .ptable tfoot tr { background: #002D72 !important; }
      .ptable tfoot td { color: white !important; }
      .ptable tbody tr:nth-child(even) { background: #F5F7FB !important; }

      /* KPIs */
      .print-kpi { background: #F5F7FB !important; }
      .print-kpi-val { color: #002D72 !important; }

      /* Memorial */
      .print-memorial-card-hdr { background: #002D72 !important; color: white !important; }
      .print-memorial-val { color: #002D72 !important; }

      @page { margin: 0.8cm; size: A3 landscape; }
    }
  </style>
</head>
