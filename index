// ═══════════════════════════════════════════════════════
// GANTT SVG
// ═══════════════════════════════════════════════════════
function renderGantt() {
  const acts = GANTT_DATA;
  if (!acts.length) {
    setEl("gantt-scroll","<div class='empty-state'><div class='empty-state-icon'>📅</div><p>Configure a obra e adicione serviços.</p></div>");
    return;
  }

  const maxDay  = acts.reduce((m,a)=>Math.max(m,a.termino),0);
  const durM    = Math.ceil(maxDay/30);
  const nKm     = parseInt(getV("obra-frentes"))||1;
  document.getElementById("gantt-meta").innerHTML =
    `Duração: <strong style="color:var(--azul)">${maxDay} dias (${durM} meses)</strong> &nbsp;·&nbsp; Extensão: <strong style="color:var(--azul)">${getV("obra-extensao")} km</strong> &nbsp;·&nbsp; Defasagem: <strong style="color:var(--amarelo)">${getV("obra-defasagem")} dias/frente</strong>`;

  const PPD    = 3.5;
  const ROW_H  = 30;
  const HDR_H  = 56;
  const LBLW   = 300;
  const nWeeks = Math.ceil(maxDay/7)+3;
  const TLW    = nWeeks*7*PPD;
  const SVG_W  = LBLW + TLW;
  const SVG_H  = HDR_H + acts.length*ROW_H + 4;

  const startDate = getV("obra-inicio") ? new Date(getV("obra-inicio")+"T00:00:00") : new Date();
  const monthLabels = [];
  let d = 0;
  while (d < maxDay+32) {
    const dt = new Date(startDate.getTime()+d*86400000);
    const label = dt.toLocaleDateString("pt-BR",{month:"short",year:"2-digit"}).replace(".","").toUpperCase();
    monthLabels.push({day:d,label});
    const next = new Date(dt.getFullYear(), dt.getMonth()+1, 1);
    d = Math.round((next-startDate)/86400000);
    if (d > maxDay+35) break;
  }

  let svg = `<svg id="gantt-svg" width="${SVG_W}" height="${SVG_H}" style="display:block;font-family:'Outfit',sans-serif">`;
  svg += `<rect width="${SVG_W}" height="${SVG_H}" fill="white"/>`;
  svg += `<rect width="${SVG_W}" height="${HDR_H}" fill="#002D72"/>`;

  // Faixas alternadas
  for (let w=0;w<nWeeks;w++) {
    svg += `<rect x="${LBLW+w*7*PPD}" y="${HDR_H}" width="${7*PPD}" height="${SVG_H-HDR_H}" fill="${w%2===0?"#F5F7FB":"white"}" opacity="0.8"/>`;
  }
  // Linhas mensais
  monthLabels.forEach(ml=>{
    svg += `<line x1="${LBLW+ml.day*PPD}" y1="${HDR_H}" x2="${LBLW+ml.day*PPD}" y2="${SVG_H}" stroke="#C4D0E8" stroke-width="1" stroke-dasharray="3,3"/>`;
    svg += `<text x="${LBLW+ml.day*PPD+4}" y="18" font-size="9" fill="#F5A623" font-weight="700">${ml.label}</text>`;
  });
  // Semanas
  for (let w=0;w<nWeeks;w++) {
    svg += `<text x="${LBLW+w*7*PPD+2}" y="${HDR_H-7}" font-size="7" fill="rgba(255,255,255,0.5)">S${String(w+1).padStart(2,"0")}</text>`;
  }
  // Cabeçalhos fixos
  svg += `<rect x="0" y="0" width="${LBLW}" height="${HDR_H}" fill="#002D72"/>`;
  svg += `<text x="8" y="${HDR_H/2+4}" font-size="9" fill="rgba(255,255,255,0.7)" font-weight="700">KM</text>`;
  svg += `<text x="52" y="${HDR_H/2+4}" font-size="9" fill="rgba(255,255,255,0.7)" font-weight="700">ATIVIDADE</text>`;
  svg += `<text x="248" y="${HDR_H/2+4}" font-size="8" fill="rgba(245,166,35,0.9)" font-weight="700" text-anchor="middle">INI</text>`;
  svg += `<text x="278" y="${HDR_H/2+4}" font-size="8" fill="rgba(245,166,35,0.9)" font-weight="700" text-anchor="middle">DUR</text>`;
  svg += `<line x1="${LBLW}" y1="0" x2="${LBLW}" y2="${SVG_H}" stroke="#C4D0E8" stroke-width="1"/>`;
  svg += `<line x1="285" y1="${HDR_H}" x2="285" y2="${SVG_H}" stroke="#E0E6F0" stroke-width="0.5"/>`;

  // Linhas de atividades
  acts.forEach((act,i)=>{
    const y   = HDR_H+i*ROW_H;
    const cor = etapaCor(act.etapa);
    const barX = LBLW+(act.inicio-1)*PPD;
    const barW = Math.max(act.duracao*PPD,4);
    const bg   = i%2===0?"#F5F7FB":"#ffffff";
    svg += `<rect x="0" y="${y}" width="${LBLW}" height="${ROW_H}" fill="${bg}"/>`;
    svg += `<line x1="0" y1="${y+ROW_H}" x2="${SVG_W}" y2="${y+ROW_H}" stroke="#E0E6F0" stroke-width="0.5"/>`;
    svg += `<text x="8" y="${y+ROW_H/2+4}" font-size="8" fill="#8896A8">${act.km}</text>`;
    const label = act.atividade.length>30?act.atividade.substring(0,28)+"…":act.atividade;
    svg += `<text x="52" y="${y+ROW_H/2+4}" font-size="8.5" fill="#1A2540">${label}</text>`;
    svg += `<text x="248" y="${y+ROW_H/2+4}" font-size="8" fill="#4A5568" text-anchor="middle">${act.inicio}</text>`;
    svg += `<text x="278" y="${y+ROW_H/2+4}" font-size="8" fill="${cor}" text-anchor="middle" font-weight="700">${act.duracao}d</text>`;
    // Barra
    svg += `<rect x="${barX}" y="${y+5}" width="${barW}" height="${ROW_H-10}" fill="${cor}" rx="4" opacity="0.85"/>`;
    if (barW>30) {
      const bl = act.atividade.split(" ")[0].substring(0,8);
      svg += `<text x="${barX+6}" y="${y+ROW_H/2+4}" font-size="7.5" fill="white" font-weight="700">${bl}</text>`;
    }
  });

  svg += "</svg>";
  document.getElementById("gantt-scroll").innerHTML = svg;

  // Legenda
  const etapasU = [...new Set(GANTT_DATA.map(a=>a.etapa))];
  setEl("gantt-legend", etapasU.map(e=>`
    <div class="legend-item">
      <div class="legend-dot" style="background:${etapaCor(e)}"></div>${e}
    </div>
  `).join(""));
}

// ═══════════════════════════════════════════════════════
// HISTOGRAMAS
// ═══════════════════════════════════════════════════════
function renderHistogramas() {
  const data = HIST_DATA;
  const labels = data.map(d=>d.mes);

  // Destrói charts anteriores
  if (chartMO)  { chartMO.destroy();  chartMO=null; }
  if (chartEQP) { chartEQP.destroy(); chartEQP=null; }

  const hasMO  = data.some(d=>d.servente+d.pedreiro+d.operador+d.carpinteiro>0);
  const hasEQP = data.some(d=>d.escavadeira+d.rolo+d.caminhao+d.moto>0);

  const CHART_CFG = {
    type:'bar',
    options:{
      responsive:true, maintainAspectRatio:false,
      plugins:{ legend:{ labels:{ font:{family:"Outfit",size:11}, color:"#4A5568" } } },
      scales:{
        x:{ stacked:true, grid:{display:false}, ticks:{font:{family:"Outfit",size:10},color:"#8896A8"} },
        y:{ stacked:true, grid:{color:"#F0F0F0"}, ticks:{font:{family:"Outfit",size:10},color:"#8896A8"} }
      }
    }
  };

  if (hasMO) {
    chartMO = new Chart(document.getElementById("chart-mo"), {
      ...CHART_CFG,
      data:{
        labels,
        datasets:[
          {label:"Serventes",    data:data.map(d=>d.servente),    backgroundColor:"#1565C0", borderRadius:2},
          {label:"Pedreiros",    data:data.map(d=>d.pedreiro),    backgroundColor:"#0288D1", borderRadius:2},
          {label:"Operadores",   data:data.map(d=>d.operador),    backgroundColor:"#0097A7", borderRadius:2},
          {label:"Carpinteiros", data:data.map(d=>d.carpinteiro), backgroundColor:"#80DEEA", borderRadius:2},
        ]
      }
    });
  }

  if (hasEQP) {
    chartEQP = new Chart(document.getElementById("chart-eqp"), {
      ...CHART_CFG,
      data:{
        labels,
        datasets:[
          {label:"Escavadeiras", data:data.map(d=>d.escavadeira), backgroundColor:"#2E7D32", borderRadius:2},
          {label:"Rolos",        data:data.map(d=>d.rolo),        backgroundColor:"#558B2F", borderRadius:2},
          {label:"Caminhões",    data:data.map(d=>d.caminhao),    backgroundColor:"#9E9D24", borderRadius:2},
          {label:"Motonivelad.", data:data.map(d=>d.moto),        backgroundColor:"#F9A825", borderRadius:2},
        ]
      }
    });
  }

  // Tabela histogramas
  const tbody = data.map((m,i)=>{
    const totMO  = m.servente+m.pedreiro+m.operador+m.carpinteiro;
    const totEQP = m.escavadeira+m.rolo+m.caminhao+m.moto;
    if (!totMO && !totEQP) return "";
    const td = (v,cor) => `<td class="right" style="color:${v>0?cor:"var(--cinza-aux)"};${v>0?"font-weight:600":""}">${v||"—"}</td>`;
    return `<tr>
      <td><strong>${m.mes}</strong></td>
      ${td(m.servente,"#0277BD")}${td(m.pedreiro,"#0277BD")}${td(m.operador,"#0277BD")}${td(m.carpinteiro,"#0277BD")}
      <td class="right" style="color:${totMO>0?"#002D72":"var(--cinza-aux)"};font-weight:700">${totMO||"—"}</td>
      ${td(m.escavadeira,"#2E7D32")}${td(m.rolo,"#2E7D32")}${td(m.caminhao,"#2E7D32")}${td(m.moto,"#2E7D32")}
      <td class="right" style="color:${totEQP>0?"#1B5E20":"var(--cinza-aux)"};font-weight:700">${totEQP||"—"}</td>
    </tr>`;
  }).join("");
  setEl("tbody-hist", tbody || "<tr><td colspan='11'><div class='empty-state'><p>Sem dados calculados.</p></div></td></tr>");
}

