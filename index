            ["Responsável",     getV("obra-responsavel")],
            ["CREA-AM",         getV("obra-crea")],
            ["E-mail",          getV("obra-email")],
          ].map(([l,v])=>`<div style="background:var(--cinza-bg);border-radius:6px;padding:0.65rem 0.9rem">
            <div style="font-size:0.6rem;font-weight:700;color:var(--cinza-aux);text-transform:uppercase;letter-spacing:0.08em;margin-bottom:0.2rem">${l}</div>
            <div style="font-size:0.82rem;font-weight:600;color:var(--azul)">${v||"—"}</div>
          </div>`).join("")}
        </div>
        <div style="margin-top:0.5rem">
          <div style="font-size:0.65rem;font-weight:700;color:var(--cinza-aux);text-transform:uppercase;letter-spacing:0.1em;margin-bottom:0.6rem">Parâmetros por Etapa — ${getV("obra-tipo")}</div>
          <div style="display:flex;gap:0.6rem;flex-wrap:wrap;">
            ${(PARAMETROS[getV("obra-tipo")]||[]).map(p=>`
              <div style="background:var(--cinza-bg);border-radius:6px;padding:0.55rem 0.9rem;border-left:3px solid ${etapaCor(p.etapa)}">
                <div style="font-size:0.55rem;color:var(--cinza-aux);font-weight:600">${p.porKm?"Por KM":"Global"}</div>
                <div style="font-size:0.75rem;font-weight:600;color:var(--cinza-txt)">${p.etapa}</div>
                <div style="font-size:1.1rem;font-weight:800;color:var(--azul)">${p.prazo} <span style="font-size:0.6rem;font-weight:400;color:var(--cinza-aux)">dias</span></div>
              </div>`).join("")}
          </div>
        </div>
      </div>
    </div>`;
  }

  // ── PÁGINA 2: EAP ──
  if (checks.eap && EAP_CALC.length > 0) {
    const jornada = parseInt(getV("obra-jornada"))||8;
    const totMO   = EAP_CALC.reduce((s,c)=>s+c.moTotal,0);
    const totQMO  = {servente:0,pedreiro:0,operador:0,carpinteiro:0};
    const totEQP  = {escavadeira:0,rolo:0,caminhao:0,moto:0};
    EAP_CALC.forEach(c=>{
      Object.keys(totQMO).forEach(k=>{totQMO[k]+=c.qmo[k]||0;});
      Object.keys(totEQP).forEach(k=>{totEQP[k]+=c.eqp[k]||0;});
    });

    html += `<div class="print-page">
      <div class="print-section-title">📊 EAP — Estrutura Analítica do Projeto</div>
      <div class="print-section-body">
        <div class="print-kpis">
          ${[
            {l:"MO Total",v:numBR(totMO,0),u:"horas·homem"},
            {l:"Serventes",v:totQMO.servente,u:"pico simultâneo"},
            {l:"Operadores",v:totQMO.operador,u:"pico simultâneo"},
            {l:"Escavadeiras",v:totEQP.escavadeira,u:"pico simultâneo"},
            {l:"Caminhões",v:totEQP.caminhao,u:"pico simultâneo"},
          ].map(k=>`<div class="print-kpi"><div class="print-kpi-lbl">${k.l}</div><div class="print-kpi-val">${k.v}</div><div class="print-kpi-unit">${k.u}</div></div>`).join("")}
        </div>
        <table class="ptable">
          <thead><tr>
            <th>#</th><th>Etapa</th><th style="min-width:180px">Serviço</th>
            <th>KM</th><th>Unid</th><th class="r">Qtde</th>
            <th class="r" style="background:rgba(2,119,189,0.5)">MO(h)</th>
            <th class="r" style="background:rgba(2,119,189,0.5)">DP</th>
            <th class="r">QE</th>
            <th class="r" style="background:rgba(245,166,35,0.5)">DA</th>
            <th class="r" style="background:rgba(2,119,189,0.3)">Serv</th>
            <th class="r" style="background:rgba(2,119,189,0.3)">Oper</th>
            <th class="r" style="background:rgba(2,119,189,0.3)">Carp</th>
            <th class="r" style="background:rgba(46,125,50,0.3)">Escav</th>
            <th class="r" style="background:rgba(46,125,50,0.3)">Rolo</th>
            <th class="r" style="background:rgba(46,125,50,0.3)">Cam</th>
            <th class="r" style="background:rgba(46,125,50,0.3)">Moto</th>
          </tr></thead>
          <tbody>
            ${EAP_CALC.map((c,i)=>`<tr>
              <td style="text-align:right;color:var(--cinza-aux)">${i+1}</td>
              <td><span style="display:inline-block;width:8px;height:8px;border-radius:50%;background:${etapaCor(c.etapa)};margin-right:4px;"></span>${c.etapa}</td>
              <td style="font-size:0.68rem"><span style="color:var(--cinza-aux)">${c.codigo} </span>${c.comp?.desc||""}</td>
              <td style="color:var(--cinza-aux)">${c.km?"KM "+c.km:"—"}</td>
              <td style="color:var(--cinza-aux)">${c.comp?.unid||""}</td>
              <td class="r">${numBR(c.qtde)}</td>
              <td class="r" style="color:#0277BD;font-weight:700">${numBR(c.moTotal,1)}</td>
              <td class="r" style="color:#0277BD">${c.dp}</td>
              <td class="r">${c.qe}</td>
              <td class="r" style="color:var(--amarelo);font-weight:700">${c.da}</td>
              <td class="r" style="color:${c.qmo.servente>0?"#0277BD":"var(--cinza-aux)"}">${c.qmo.servente||"—"}</td>
              <td class="r" style="color:${c.qmo.operador>0?"#0277BD":"var(--cinza-aux)"}">${c.qmo.operador||"—"}</td>
              <td class="r" style="color:${c.qmo.carpinteiro>0?"#0277BD":"var(--cinza-aux)"}">${c.qmo.carpinteiro||"—"}</td>
              <td class="r" style="color:${c.eqp.escavadeira>0?"#2E7D32":"var(--cinza-aux)"}">${c.eqp.escavadeira||"—"}</td>
              <td class="r" style="color:${c.eqp.rolo>0?"#2E7D32":"var(--cinza-aux)"}">${c.eqp.rolo||"—"}</td>
              <td class="r" style="color:${c.eqp.caminhao>0?"#2E7D32":"var(--cinza-aux)"}">${c.eqp.caminhao||"—"}</td>
              <td class="r" style="color:${c.eqp.moto>0?"#2E7D32":"var(--cinza-aux)"}">${c.eqp.moto||"—"}</td>
            </tr>`).join("")}
          </tbody>
          <tfoot><tr>
            <td colspan="6" style="text-align:right;font-size:0.6rem;letter-spacing:0.08em">TOTAIS</td>
            <td class="r">${numBR(totMO,1)}</td>
            <td></td><td></td><td></td>
            <td class="r">${totQMO.servente}</td>
            <td class="r">${totQMO.operador}</td>
            <td class="r">${totQMO.carpinteiro}</td>
            <td class="r">${totEQP.escavadeira}</td>
            <td class="r">${totEQP.rolo}</td>
            <td class="r">${totEQP.caminhao}</td>
            <td class="r">${totEQP.moto}</td>
          </tr></tfoot>
        </table>
        <div style="margin-top:0.8rem;display:flex;flex-wrap:wrap;gap:1rem;font-size:0.65rem;color:var(--cinza-aux);background:var(--cinza-bg);border-radius:6px;padding:0.6rem 1rem">
          <span><strong style="color:var(--azul)">DP</strong> = ROUNDUP(MO_Total / ${getV("obra-jornada")}h, 0)</span>
          <span><strong style="color:var(--azul)">DA</strong> = ROUNDUP(DP / QE, 0)</span>
          <span><strong style="color:var(--azul)">QMO</strong> = ROUNDUP(Qtde × taxa / (DA × Jornada), 0)</span>
          <span>Fonte: DNIT-313 / SICRO2 / CPU / e-Obras</span>
        </div>
      </div>
    </div>`;
  }

  // ── PÁGINA 3: GANTT ──
  if (checks.gantt && GANTT_DATA.length > 0) {
    // Captura o SVG gerado
    const ganttSVG = document.getElementById("gantt-svg");
    let ganttContent = "";
    if (ganttSVG && ganttSVG.outerHTML && ganttSVG.getAttribute("width")) {
      ganttContent = `<div class="print-gantt-wrap" style="overflow-x:auto">${ganttSVG.outerHTML}</div>`;
    } else {
      // Re-gera o gantt para captura
      renderGantt();
      const g2 = document.getElementById("gantt-svg");
      ganttContent = g2 && g2.getAttribute("width")
        ? `<div class="print-gantt-wrap" style="overflow-x:auto">${g2.outerHTML}</div>`
        : "<p style='color:var(--cinza-aux);padding:1rem'>Acesse a aba Cronograma antes de imprimir para gerar o Gantt.</p>";
    }

    const maxDia = GANTT_DATA.reduce((m,a)=>Math.max(m,a.termino),0);
    html += `<div class="print-page">
      <div class="print-section-title">📅 Cronograma Físico — Gráfico de Gantt</div>
      <div class="print-section-body">
        <div style="display:flex;gap:2rem;margin-bottom:0.8rem;font-size:0.75rem;">
          <span>Duração total: <strong style="color:var(--azul)">${maxDia} dias (${Math.ceil(maxDia/30)} meses)</strong></span>
          <span>Extensão: <strong style="color:var(--azul)">${getV("obra-extensao")} km</strong></span>
          <span>Frentes: <strong style="color:var(--azul)">${getV("obra-frentes")}</strong></span>
          <span>Defasagem: <strong style="color:var(--amarelo)">${getV("obra-defasagem")} dias/frente</strong></span>
        </div>
        ${ganttContent}
        <div style="display:flex;gap:1rem;flex-wrap:wrap;margin-top:0.8rem;">
          ${[...new Set(GANTT_DATA.map(a=>a.etapa))].map(e=>`
            <div style="display:flex;align-items:center;gap:5px;font-size:0.68rem;color:var(--cinza-aux)">
              <div style="width:10px;height:10px;border-radius:2px;background:${etapaCor(e)}"></div>${e}
            </div>`).join("")}
        </div>
        <div style="margin-top:1rem">
          <table class="ptable">
            <thead><tr><th>KM</th><th>Atividade</th><th class="r">Início (dia)</th><th class="r">Duração</th><th class="r">Término (dia)</th></tr></thead>
            <tbody>${GANTT_DATA.map(a=>`<tr>
              <td style="color:var(--cinza-aux)">${a.km}</td>
              <td><span style="display:inline-block;width:8px;height:8px;border-radius:2px;background:${etapaCor(a.etapa)};margin-right:5px"></span>${a.atividade}</td>
              <td class="r">${a.inicio}</td>
              <td class="r" style="color:var(--amarelo);font-weight:700">${a.duracao}d</td>
              <td class="r">${a.termino}</td>
            </tr>`).join("")}</tbody>
          </table>
        </div>
      </div>
    </div>`;
  }

  // ── PÁGINA 4: HISTOGRAMAS ──
  if (checks.histogramas) {
    // Captura imagens dos canvas Chart.js
    const canvasMO  = document.getElementById("chart-mo");
    const canvasEQP = document.getElementById("chart-eqp");
    let imgMO = "", imgEQP = "";
    try { imgMO  = canvasMO?.toDataURL("image/png")  || ""; } catch(e){}
    try { imgEQP = canvasEQP?.toDataURL("image/png") || ""; } catch(e){}

    const hasMO  = HIST_DATA.some(d=>d.servente+d.pedreiro+d.operador+d.carpinteiro>0);
    const hasEQP = HIST_DATA.some(d=>d.escavadeira+d.rolo+d.caminhao+d.moto>0);

    html += `<div class="print-page">
      <div class="print-section-title">📈 Histogramas — Distribuição Mensal de Recursos</div>
      <div class="print-section-body">
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:1.2rem;margin-bottom:1.2rem">
          <div style="background:var(--cinza-bg);border-radius:8px;padding:1rem">
            <div style="font-size:0.7rem;font-weight:700;color:var(--azul);text-transform:uppercase;letter-spacing:0.06em;margin-bottom:0.7rem">Histograma de Mão de Obra</div>
            ${imgMO ? `<img src="${imgMO}" style="width:100%;border-radius:4px" alt="Histograma MO"/>` : "<p style='color:var(--cinza-aux);font-size:0.8rem'>Acesse a aba Histogramas antes de imprimir.</p>"}
          </div>
          <div style="background:var(--cinza-bg);border-radius:8px;padding:1rem">
            <div style="font-size:0.7rem;font-weight:700;color:var(--azul);text-transform:uppercase;letter-spacing:0.06em;margin-bottom:0.7rem">Histograma de Equipamentos</div>
            ${imgEQP ? `<img src="${imgEQP}" style="width:100%;border-radius:4px" alt="Histograma EQP"/>` : "<p style='color:var(--cinza-aux);font-size:0.8rem'>Acesse a aba Histogramas antes de imprimir.</p>"}
          </div>
        </div>
        <table class="ptable">
          <thead><tr>
            <th>Mês</th>
            <th class="r" style="background:rgba(2,119,189,0.4)">Serv.</th>
            <th class="r" style="background:rgba(2,119,189,0.4)">Ped.</th>
            <th class="r" style="background:rgba(2,119,189,0.4)">Oper.</th>
            <th class="r" style="background:rgba(2,119,189,0.4)">Carp.</th>
            <th class="r" style="background:rgba(2,119,189,0.6)">Total MO</th>
            <th class="r" style="background:rgba(46,125,50,0.4)">Escav.</th>
            <th class="r" style="background:rgba(46,125,50,0.4)">Rolo</th>
            <th class="r" style="background:rgba(46,125,50,0.4)">Cam.</th>
            <th class="r" style="background:rgba(46,125,50,0.4)">Moto</th>
            <th class="r" style="background:rgba(46,125,50,0.6)">Total EQP</th>
          </tr></thead>
          <tbody>${HIST_DATA.map(m=>{
            const tMO  = m.servente+m.pedreiro+m.operador+m.carpinteiro;
            const tEQP = m.escavadeira+m.rolo+m.caminhao+m.moto;
            if (!tMO && !tEQP) return "";
            const c = (v, cor) => `<td class="r" style="color:${v>0?cor:"var(--cinza-aux)"};${v>0?"font-weight:600":""}">${v||"—"}</td>`;
            return `<tr>
              <td><strong>${m.mes}</strong></td>
              ${c(m.servente,"#0277BD")}${c(m.pedreiro,"#0277BD")}${c(m.operador,"#0277BD")}${c(m.carpinteiro,"#0277BD")}
              <td class="r" style="color:${tMO>0?"#002D72":"var(--cinza-aux)"};font-weight:700">${tMO||"—"}</td>
              ${c(m.escavadeira,"#2E7D32")}${c(m.rolo,"#2E7D32")}${c(m.caminhao,"#2E7D32")}${c(m.moto,"#2E7D32")}
              <td class="r" style="color:${tEQP>0?"#1B5E20":"var(--cinza-aux)"};font-weight:700">${tEQP||"—"}</td>
            </tr>`;
          }).join("")}</tbody>
        </table>
      </div>
    </div>`;
  }

  // ── PÁGINA 5: MEMORIAL ──
  if (checks.memorial) {
    const dataIni  = getV("obra-inicio");
    const maxDia   = GANTT_DATA.reduce((m,a)=>Math.max(m,a.termino),0);
    const dataFim  = dataIni && maxDia
      ? new Date(new Date(dataIni+"T00:00:00").getTime()+maxDia*86400000).toLocaleDateString("pt-BR")
      : "—";
    const moTotal  = EAP_CALC.reduce((s,c)=>s+c.moTotal,0);
    const maxQMO   = q => EAP_CALC.length ? Math.max(...EAP_CALC.map(c=>c.qmo[q]||0)) : 0;
    const maxEQP   = q => EAP_CALC.length ? Math.max(...EAP_CALC.map(c=>c.eqp[q]||0)) : 0;

    const mCard = (title, rows) => `
      <div class="print-memorial-card">
        <div class="print-memorial-card-hdr">${title}</div>
        ${rows.map(([l,v])=>`<div class="print-memorial-row">
          <div class="print-memorial-lbl">${l}</div>
          <div class="print-memorial-val">${v||"—"}</div>
        </div>`).join("")}
      </div>`;

    html += `<div class="print-page">
      <div class="print-section-title">📄 Memorial de Execução</div>
      <div class="print-section-body">
        <div class="print-memorial-grid">
          ${mCard("👷 Responsabilidade Técnica",[
            ["Responsável",  getV("obra-responsavel")],
            ["CREA-AM",      getV("obra-crea")],
            ["Cargo",        getV("obra-cargo")],
            ["E-mail",       getV("obra-email")],
          ])}
          ${mCard("📋 Identificação da Obra",[
            ["Nome da Obra",  getV("obra-nome")],
            ["Nº Orçamento",  getV("obra-orcamento")],
            ["Tipo de Modal", getV("obra-tipo")],
            ["Localização",   getV("obra-local")],
            ["Rodovia / KM",  getV("obra-rodovia")],
            ["Extensão",      getV("obra-extensao")+" km"],
          ])}
          ${mCard("📅 Planejamento Temporal",[
            ["Data de Início",    dataIni ? new Date(dataIni+"T00:00:00").toLocaleDateString("pt-BR") : "—"],
            ["Data de Término",   dataFim],
            ["Duração Total",     `${maxDia} dias (${Math.ceil(maxDia/30)} meses)`],
            ["Jornada",           getV("obra-jornada")+"h/dia"],
            ["Nº de Frentes",     getV("obra-frentes")],
            ["Defasagem",         getV("obra-defasagem")+" dias"],
          ])}
          ${mCard("👷‍♂️ Dimensionamento de Recursos",[
            ["MO Total (h·h)",   numBR(moTotal)],
            ["Serviços",         EAP_CALC.length],
            ["Serventes (pico)", maxQMO("servente")],
            ["Operadores (pico)",maxQMO("operador")],
            ["Escavadeiras",     maxEQP("escavadeira")],
            ["Caminhões",        maxEQP("caminhao")],
          ])}
        </div>
        <div style="margin-top:1rem">
          <div style="font-size:0.65rem;font-weight:700;color:var(--cinza-aux);text-transform:uppercase;letter-spacing:0.1em;margin-bottom:0.6rem">Resumo do Cronograma</div>
          <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(170px,1fr));gap:0.6rem">
            ${GANTT_DATA.map(act=>`
              <div style="background:var(--cinza-bg);border-radius:6px;padding:0.6rem 0.8rem;border-left:3px solid ${etapaCor(act.etapa)}">
                <div style="font-size:0.58rem;color:var(--cinza-aux);margin-bottom:0.15rem">${act.km} · Dias ${act.inicio}–${act.termino}</div>
                <div style="font-size:0.78rem;font-weight:600;color:var(--cinza-txt)">${act.atividade}</div>
                <div style="font-size:1rem;font-weight:800;color:var(--azul)">${act.duracao}d</div>
              </div>`).join("")}
          </div>
        </div>
        <!-- Rodapé do documento -->
        <div style="margin-top:1.5rem;padding-top:0.8rem;border-top:1px solid var(--borda);display:flex;justify-content:space-between;align-items:flex-end;font-size:0.62rem;color:var(--cinza-aux)">
          <div>
            <div style="font-weight:700;color:var(--azul);font-size:0.75rem">SEINFRA/AM</div>
            <div>Secretaria de Estado de Infraestrutura · Amazonas</div>
            <div>Plataforma de Planejamento de Obras v2.0 · DMOB</div>
          </div>
          <div style="text-align:right">
            <div>Emitido em: ${new Date().toLocaleDateString("pt-BR", {day:"2-digit",month:"long",year:"numeric"})}</div>
            <div>Responsável: ${getV("obra-responsavel")||"—"} · ${getV("obra-crea")||"—"}</div>
          </div>
        </div>
      </div>
    </div>`;
  }

  if (!html) {
    html = `<div style="text-align:center;padding:3rem;color:var(--cinza-aux)">
      <div style="font-size:2rem;margin-bottom:0.8rem">📋</div>
      <p>Selecione ao menos uma seção para visualizar o preview.</p>
    </div>`;
  }

  area.innerHTML = html;
}

// ═══════════════════════════════════════════════════════
// INICIALIZAÇÃO
// ═══════════════════════════════════════════════════════
(function init() {
  // Data padrão: hoje
  const today = new Date().toISOString().split("T")[0];
  document.getElementById("obra-inicio").value = today;

  renderParamCards();
  calcularTudo();

  // Monitorar mudanças nos campos de parâmetros
  ["obra-jornada","obra-defasagem","obra-inicio"].forEach(id => {
    document.getElementById(id)?.addEventListener("input", calcularTudo);
  });
})();
</script>
</body>
</html>
