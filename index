// EXPORTAR CSV
// ═══════════════════════════════════════════════════════
function exportarCSV() {
  if (!EAP_CALC.length) { alert("Nenhum dado para exportar."); return; }
  const header = ["#","Etapa","Serviço","KM","Unid","Qtde","Produt","MO_Total_h","DP_d","QE","DA_d","Serventes","Pedreiros","Operadores","Carpinteiros","Escavadeiras","Rolos","Caminhoes","Motonivelad"];
  const rows = EAP_CALC.map((c,i)=>[
    i+1, c.etapa, `"${c.comp?.desc}"`, c.km||"", c.comp?.unid, c.qtde, c.comp?.produt,
    c.moTotal.toFixed(1), c.dp, c.qe, c.da,
    c.qmo.servente, c.qmo.pedreiro, c.qmo.operador, c.qmo.carpinteiro,
    c.eqp.escavadeira, c.eqp.rolo, c.eqp.caminhao, c.eqp.moto
  ].join(","));
  const csv = [header.join(","), ...rows].join("\n");
  const blob = new Blob([csv], {type:"text/csv;charset=utf-8;"});
  const a = document.createElement("a");
  a.href = URL.createObjectURL(blob);
  a.download = `EAP_${getV("obra-nome")||"obra"}_${new Date().toISOString().split("T")[0]}.csv`;
  a.click();
}

